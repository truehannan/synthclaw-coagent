# SynthClaw-CoAgent Configuration
# Copy this file to .env and fill in your values
# Run `python setup_cli.py` for an interactive setup wizard

# ── Interface Mode ──────────────────────────────────────────
# Options: telegram | whatsapp | both
INTERFACE_MODE="telegram"

# ── Telegram ────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_TOKEN="your-telegram-bot-token-here"

# ── WhatsApp (Meta Cloud API) ───────────────────────────────
# Only needed if INTERFACE_MODE is "whatsapp" or "both"
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_TOKEN="your-whatsapp-api-token-here"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_VERIFY_TOKEN="random-string-for-webhook-verification"
WHATSAPP_PORT="8443"

# ── LLM Provider ───────────────────────────────────────────
# Any OpenAI-compatible API (OpenAI, DigitalOcean AI, Ollama, etc.)
OPENAI_API_KEY="your-api-key-here"
OPENAI_API_BASE="https://inference.do-ai.run/v1"
DEFAULT_MODEL="llama3.3-70b-instruct"

# ── Server Settings ────────────────────────────────────────
SYNTHCLAW_BASE_DIR="/opt/agent"
MAX_TOOL_ITERATIONS="10"
MAX_HISTORY_MESSAGES="20"
